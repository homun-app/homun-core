#!/bin/sh
# Pre-removal script for homun .deb package
#
# Stops the systemd unit (if running) before the binary is removed,
# so running instances don't dangle. Does NOT delete data or user —
# that belongs to postrm purge.

set -e

case "$1" in
    remove|upgrade|deconfigure)
        if [ -x /bin/systemctl ] || [ -x /usr/bin/systemctl ]; then
            if systemctl is-active --quiet homun.service 2>/dev/null; then
                systemctl stop homun.service || true
            fi
            if [ "$1" = "remove" ]; then
                systemctl disable homun.service 2>/dev/null || true
            fi
        fi
        ;;

    failed-upgrade)
        ;;

    *)
        echo "prerm called with unknown argument: $1" >&2
        exit 1
        ;;
esac

exit 0
