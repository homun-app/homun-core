{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local First Assistant",
  "version": "0.1.0",
  "identifier": "ai.localfirst.personal-assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Local First Assistant",
        "width": 1280,
        "height": 820,
        "minWidth": 860,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
