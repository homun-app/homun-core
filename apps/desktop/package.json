{
  "name": "@local-first-personal-assistant/desktop",
  "productName": "Homun",
  "version": "0.1.0",
  "description": "Homun — local-first personal assistant",
  "author": "Homun <noreply@homun.app>",
  "homepage": "https://github.com/homun-app/homun-core",
  "license": "SEE LICENSE IN LICENSE.md",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "dist": "npm run package:prepare && electron-builder",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1421",
    "electron:dev": "node scripts/electron-dev.mjs",
    "package:prepare": "node scripts/prepare-package.mjs",
    "package:smoke": "npm run package:prepare -- --skip-build && LOCAL_FIRST_DESKTOP_RESOURCES_DIR=\"$PWD/.package/resources\" LOCAL_FIRST_DESKTOP_GATEWAY_PORT=18766 LOCAL_FIRST_DESKTOP_GATEWAY_URL=http://127.0.0.1:18766 npx electron electron/main.cjs",
    "test:ui-contract": "node scripts/check-ui-contract.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "diff": "^7.0.0",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.554.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^42.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "build": {
    "appId": "app.homun.desktop",
    "productName": "Homun",
    "executableName": "homun",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist-installers",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**",
      "assets/brand/**",
      "package.json"
    ],
    "extraResources": [
      { "from": ".package/resources", "to": "." }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "maintainer": "Homun <noreply@homun.app>"
    }
  }
}
