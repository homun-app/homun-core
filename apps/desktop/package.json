{
  "name": "homun-desktop",
  "productName": "Homun",
  "version": "0.1.1",
  "description": "Homun — local-first personal assistant",
  "author": "Homun <noreply@homun.app>",
  "homepage": "https://github.com/homun-app/homun-core",
  "license": "SEE LICENSE IN LICENSE.md",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "dist": "npm run package:prepare && electron-builder",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1421",
    "electron:dev": "node scripts/electron-dev.mjs",
    "package:prepare": "node scripts/prepare-package.mjs",
    "package:smoke": "npm run package:prepare -- --skip-build && HOMUN_DESKTOP_RESOURCES_DIR=\"$PWD/.package/resources\" HOMUN_DESKTOP_GATEWAY_PORT=18766 HOMUN_DESKTOP_GATEWAY_URL=http://127.0.0.1:18766 npx electron electron/main.cjs",
    "test:ui-contract": "node scripts/check-ui-contract.mjs",
    "test:electron": "node --test tests/*.test.mjs",
    "refresh-models": "node scripts/refresh-models-catalog.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "diff": "^8.0.4",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "i18next": "^26.3.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.554.0",
    "mermaid": "^11.15.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-force-graph-2d": "^1.29.1",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@fontsource/archivo": "^5",
    "@fontsource/bitter": "^5",
    "@fontsource/crimson-pro": "^5",
    "@fontsource/dm-sans": "^5",
    "@fontsource/eb-garamond": "^5",
    "@fontsource/figtree": "^5",
    "@fontsource/fraunces": "^5",
    "@fontsource/ibm-plex-mono": "^5",
    "@fontsource/ibm-plex-sans": "^5",
    "@fontsource/inter": "^5",
    "@fontsource/karla": "^5",
    "@fontsource/lato": "^5",
    "@fontsource/libre-baskerville": "^5",
    "@fontsource/lora": "^5",
    "@fontsource/manrope": "^5",
    "@fontsource/merriweather": "^5",
    "@fontsource/montserrat": "^5",
    "@fontsource/mulish": "^5",
    "@fontsource/nunito-sans": "^5",
    "@fontsource/open-sans": "^5",
    "@fontsource/playfair-display": "^5",
    "@fontsource/plus-jakarta-sans": "^5",
    "@fontsource/poppins": "^5",
    "@fontsource/pt-serif": "^5",
    "@fontsource/roboto": "^5",
    "@fontsource/roboto-slab": "^5",
    "@fontsource/rubik": "^5",
    "@fontsource/sora": "^5",
    "@fontsource/source-sans-3": "^5",
    "@fontsource/source-serif-4": "^5",
    "@fontsource/space-grotesk": "^5",
    "@fontsource/space-mono": "^5",
    "@fontsource/spectral": "^5",
    "@fontsource/work-sans": "^5",
    "@fontsource/zilla-slab": "^5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^42.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3",
    "vite": "^7.3.5"
  },
  "overrides": {
    "vitest": "^4.1.0",
    "undici": "^7.28.0",
    "dompurify": "^3.4.11",
    "tar": "^7.5.16",
    "@babel/core": "^7.29.6",
    "esbuild": "^0.28.1"
  },
  "build": {
    "appId": "app.homun.desktop",
    "productName": "Homun",
    "executableName": "homun",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "afterPack": "./scripts/after-pack-fuses.mjs",
    "publish": {
      "provider": "github",
      "owner": "homun-app",
      "repo": "homun-releases"
    },
    "directories": {
      "output": "dist-installers",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**",
      "assets/brand/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".package/resources",
        "to": "."
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Homun <noreply@homun.app>"
    }
  }
}
